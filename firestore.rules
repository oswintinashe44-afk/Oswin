rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      // Allow optional avatar and courierDetails during creation
      let requiredKeys = ['uid', 'name', 'email', 'role', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(requiredKeys)
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 200
        && data.role in ['buyer', 'seller', 'courier']
        && (data.get('avatar', '') == '' || data.avatar is string)
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'description', 'price', 'sellerId', 'category', 'image', 'createdAt'])
        && data.keys().size() == 7
        && data.name is string && data.name.size() <= 100
        && data.description is string && data.description.size() <= 2000
        && data.price is number && data.price >= 0
        && data.sellerId == request.auth.uid
        && data.category is string
        && data.image is string
        && data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && userId == request.auth.uid; // Secure query enforcement
      
      allow create: if isOwner(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && (
        // Action: Update Profile
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'updatedAt']) 
         && incoming().updatedAt == request.time) ||
        // Action: Change Role (Only if not already set or admin-like logic)
        (incoming().diff(existing()).affectedKeys().hasOnly(['role', 'courierDetails', 'updatedAt']) 
         && incoming().role in ['buyer', 'seller', 'courier']
         && (incoming().get('courierDetails', null) == null || incoming().courierDetails.vehicle is string))
      );
    }

    match /products/{productId} {
      allow read: if true; // Public marketplace
      
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
      
      allow update: if isOwner(existing().sellerId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'image', 'category'])
        && incoming().price >= 0
      );
      
      allow delete: if isOwner(existing().sellerId);
    }

    match /orders/{orderId} {
      function userIsPartyToOrder(order) {
        return isSignedIn() && (order.buyerId == request.auth.uid || order.sellerId == request.auth.uid);
      }

      allow get: if userIsPartyToOrder(existing());
      allow list: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      
      allow create: if isSignedIn() 
        && incoming().buyerId == request.auth.uid
        && exists(/databases/$(database)/documents/products/$(incoming().productId))
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
        
      allow update: if userIsPartyToOrder(existing()) && (
        // Action: Confirm/Cancel
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
        && incoming().status in ['confirmed', 'delivered', 'cancelled']
      );

      match /messages/{messageId} {
        allow read: if userIsPartyToOrder(get(/databases/$(database)/documents/orders/$(orderId)).data);
        allow create: if userIsPartyToOrder(get(/databases/$(database)/documents/orders/$(orderId)).data)
          && incoming().senderId == request.auth.uid
          && incoming().createdAt == request.time;
      }
    }

    match /deliveries/{deliveryId} {
      allow read: if isSignedIn(); // Couriers need to see available jobs
      
      allow create: if isSignedIn(); // Usually created via system/seller, allowing for now
      
      allow update: if isSignedIn() && (
        // Action: Accept Job
        (existing().status == 'available' && incoming().status == 'picked_up' 
         && incoming().courierId == request.auth.uid 
         && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'courierId'])) ||
        // Action: Update Status (Only assigned courier)
        (existing().courierId == request.auth.uid 
         && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
         && incoming().status in ['delivering', 'completed'])
      );
    }

    match /leaderboard/{leaderId} {
      allow read: if true; // Hall of Fame is public
    }
  }
}
